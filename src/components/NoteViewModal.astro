---
import { actions } from "astro:actions";
import { getCurrentPlayerId } from "../db/utils/session";
import DeleteNoteButton from "./dynamic/DeleteNoteButton";

const gameId = Astro.props.gameId;
const note = Astro.props.note;

const userId = await getCurrentPlayerId(Astro.cookies);
if (!userId) {
  console.error("No user logged in, redirecting to /");
  return Astro.redirect("/");
}

---

<div class="absolute card w-200 h-fit bg-base-200 rounded-tl-none border-2">
  <form class="card-body" action={actions.updateNote} method="POST">
    <input type="hidden" name="id" value={note.id} />
    <input type="hidden" name="gameId" value={gameId} />
    {/* HEADER LINE  */}
    <div class="flex justify-between mb-2">
      <div class="group/title w-full mr-4 focus:outline-0" contenteditable="true">
        <h1 class="card-title pb-2 border-b-1 group-focus-within/title:hidden" id={`titleTarget-${note.id}`}>{note.title}</h1>
        <input 
        type="text"
        name="title"
        id={`titleInput-${note.id}`}
        placeholder="Title"
        value={note.title}
        class={"input input-bordered input-sm w-140 hidden group-focus-within/title:flex"}/>
      </div>
      <div class="flex align-middle mb-2">
        <div class="tooltip" data-tip="Save note">
          <button type="submit" id={`saveNote-${note.id}`} class="btn btn-circle btn-primary w-8 h-8 mr-4" disabled><img class="w-6 h-6" src="/icons/save.svg"/></button>
        </div>
        <DeleteNoteButton id={note.id} client:only="/"/>
        <div class="tooltip" data-tip="Share note to game">
          <a type="button" href={`/toolkit/game/${gameId}`} class="btn btn-circle btn-primary w-8 h-8 mr-4"><img class="w-6 h-6" src="/icons/triangle_right.svg"/></a>
        </div>
      </div>
    </div>
      
    {/* CONTENT */}
    <div class="flex w-full justify-between">
      <div class={"group/note focus:outline-0 w-full"} contenteditable="true"> <!-- TODO: Once img can be given switch to w-7/11 -->
        <p class="max-h-80 overflow-auto whitespace-pre-wrap group-focus-within/note:hidden" id=`noteTarget-${note.id}`>{note.note}</p>
        <textarea 
        name="note"
        id=`noteInput-${note.id}`
        placeholder="Note"
        class="input input-bordered input-sm w-full h-80 overflow-auto hidden group-focus-within/note:flex">{note.note}</textarea>
      </div>
      <!-- TODO: Implement notes with images below -->
      {
        note.imgSrc &&
        <div class="flex flex-col w-4/11 items-end">
          <img class="w-6 h-6" src={note.imgSrc} />
        </div>
      }
    </div>
  </form>
</div>